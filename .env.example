# =============================================================================
# EdgeTwin-BMS+ Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=EdgeTwin-BMS+
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Database (PostgreSQL + TimescaleDB)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edgetwin_bms
POSTGRES_USER=edgetwin
POSTGRES_PASSWORD=edgetwin_secret_password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# -----------------------------------------------------------------------------
# MQTT
# -----------------------------------------------------------------------------
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=edgetwin-backend
MQTT_TELEMETRY_TOPIC=edgetwin/+/telemetry
MQTT_ALERTS_TOPIC=edgetwin/+/alerts
MQTT_COMMANDS_TOPIC=edgetwin/+/commands
MQTT_QOS=1
MQTT_KEEPALIVE=60

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Frontend (React)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_MQTT_URL=ws://localhost:9001
VITE_APP_NAME=EdgeTwin-BMS+

# -----------------------------------------------------------------------------
# AI Models
# -----------------------------------------------------------------------------
AI_MODELS_DIR=/app/ai/models
AI_MODEL_VERSION=1.0.0
AI_INFERENCE_DEVICE=cpu
AI_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# TimescaleDB
# -----------------------------------------------------------------------------
TIMESCALE_VERSION=2.14.2

# -----------------------------------------------------------------------------
# Mosquitto MQTT Broker
# -----------------------------------------------------------------------------
MOSQUITTO_PORT=1883
MOSQUITTO_WEBSOCKET_PORT=9001
MOSQUITTO_CONFIG_FILE=/mosquitto/config/mosquitto.conf

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_FORMAT=json
LOG_FILE=/app/logs/edgetwin.log
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Rate Limiting
#-------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# -----------------------------------------------------------------------------
# Email (for alerts)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_RECIPIENTS=
